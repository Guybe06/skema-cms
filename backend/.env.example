# Application
APP_PORT=3000
APP_ENV=development

# Base de données CMS (PostgreSQL)
CMS_DB_HOST=localhost
CMS_DB_PORT=5432
CMS_DB_NAME=skema
CMS_DB_USER=postgres
CMS_DB_PASSWORD=

# Cache (Redis)
REDIS_URL=redis://localhost:6379

# Authentification JWT
JWT_SECRET=
JWT_EXPIRATION=7d

# Chiffrement des credentials clients (exactement 32 caractères)
ENCRYPTION_KEY=

# Email (Resend)
MAILER_FROM=noreply@skema.app
RESEND_API_KEY=

# Stockage fichiers
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_S3_ENDPOINT=
STORAGE_S3_BUCKET=
STORAGE_S3_KEY=
STORAGE_S3_SECRET=

# URLs
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
